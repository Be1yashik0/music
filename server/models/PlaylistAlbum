const { DataTypes } = require('sequelize')
const sequelize = require('../config/db')

const PlaylistAlbum = sequelize.define('PlaylistAlbum', {
  playlist_id: {
    type: DataTypes.INTEGER,
    references: {
      model: 'playlists',
      key: 'id',
    },
  },
  album_id: {
    type: DataTypes.INTEGER,
    references: {
      model: 'albums',
      key: 'album_id',
    },
  },
}, {
  tableName: 'playlist_albums',
  timestamps: false,
})

module.exports = (sequelize, DataTypes) => PlaylistAlbum